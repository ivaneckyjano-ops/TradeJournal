import pandas as pd
import sys

# Cesta k suboru
file_path = "/home/narbon/Dokumenty/Archiv/SAXO/Saxo_Danove_Podklady_20242025_FINAL_v.00.ods"

# Funkcia na konverziu stringu na cislo
def to_numeric(val):
    if pd.isna(val):
        return 0.0
    if isinstance(val, (int, float)):
        return float(val)
    if isinstance(val, str):
        # Odstranenie medzier a nahradenie ciarky bodkou
        cleaned = val.replace(' ', '').replace(',', '.').replace('\xa0', '')
        try:
            return float(cleaned)
        except ValueError:
            return val
    return val

try:
    # Nacitanie vsetkych listov
    all_sheets = pd.read_excel(file_path, sheet_name=None, engine='odf')
    
    # Zaloha povodneho suboru
    import shutil
    shutil.copy2(file_path, file_path + ".bak")
    print(f"Zaloha vytvorena: {file_path}.bak")

    with pd.ExcelWriter(file_path, engine='odf') as writer:
        for sheet_name, df in all_sheets.items():
            print(f"Spracovavam list: {sheet_name}")
            
            # Indexy stlpcov F, G, H su 5, 6, 7 (ak rátame od 0)
            # F = 5, G = 6, H = 7
            cols_to_convert = [5, 6, 7]
            
            for col_idx in cols_to_convert:
                if col_idx < len(df.columns):
                    col_name = df.columns[col_idx]
                    print(f"  Konvertujem stlpec: {col_name} (index {col_idx})")
                    df.iloc[:, col_idx] = df.iloc[:, col_idx].apply(to_numeric)
            
            # Ulozenie listu spat
            df.to_excel(writer, sheet_name=sheet_name, index=False)
            
    print("Subor bol uspesne aktualizovany.")

except Exception as e:
    print(f"Chyba: {e}")
    sys.exit(1)
